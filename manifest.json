{
  "manifest_version": 2,
  "name": "Firefox Multicol Reader",
  "version": "0.1.0",
  "description": "Select a page container and render it in multi-column reading mode.",
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "browser_action": {
    "default_title": "Toggle multi-column reader",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png",
      "128": "icons/icon-128.png"
    }
  },
  "applications": {
    "gecko": {
      "id": "firefox-multicol-reader@example.local",
      "strict_min_version": "109.0"
    }
  }
}
