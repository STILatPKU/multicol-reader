{
  "manifest_version": 2,
  "name": "Multicol Reader",
  "version": "0.1.0",
  "description": "Select a page container and render it in multi-column reading mode.",
  "browser_specific_settings": {
    "gecko": {
      "id": "multicol-reader@stil.code",
      "strict_min_version": "140.0",
      "update_url": "https://raw.githubusercontent.com/STILatPKU/multicol-reader/main/dist/firefox/updates.json",
      "data_collection_permissions": {
        "required": [ "none" ]
      }
    }
  },
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "browser_action": {
    "default_title": "Toggle multi-column reader",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png",
      "128": "icons/icon-128.png"
    }
  }
}
